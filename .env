# =============================================
# SOL RSI Monitor — Environment Configuration
# =============================================

# Server
PORT=3003
NODE_ENV=production

# BirdEye API (Premium Plus)
BIRDEYE_API_KEY=your_birdeye_api_key_here
BIRDEYE_BASE_URL=https://public-api.birdeye.so

# Trade Signal Webhook (outbound → your trading server)
TRADE_WEBHOOK_BUY_URL=http://43.165.7.149:3002/webhook/new-token
TRADE_WEBHOOK_SELL_URL=http://43.165.7.149:3002/force-sell

# ---- Strategy Parameters ----
# RSI 周期
RSI_PERIOD=7
# RSI 超卖线（买入上穿信号）
RSI_OVERSOLD=30
# RSI 超买线（卖出下穿信号）
RSI_OVERBOUGHT=70
# RSI 极度超买线（直接卖出）
RSI_EXTREME=80
# 监控时长上限 (分钟)
MONITOR_DURATION_MIN=30
# FDV 最低门槛 (美元)
MIN_FDV=10000
# 白名单最大代币数
MAX_WHITELIST_SIZE=10

# ---- Polling ----
# K线聚合间隔 (秒)
CANDLE_INTERVAL_SEC=5
# 价格轮询间隔 (秒)
POLL_INTERVAL_SEC=5
